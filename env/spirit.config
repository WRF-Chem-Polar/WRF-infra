#
# Plateform-specific options for compiling WRF, WRF-Chem, and WPS on Spirit.

[common]

job-exe=/usr/bin/sbatch
job-header-prefix=#SBATCH --
job-header-separator==

shell=module purge
      module load gcc/11.2.0
      module load openmpi/4.0.7
      module load netcdf-c/4.7.4-serial
      module load netcdf-fortran/4.5.3-serial

[compile.all]

job-header-option-ntasks=1
job-header-option-ntasks-per-node=1
job-header-option-output=compile.log
job-header-option-error=compile.log

shell=export NETCDF="$NETCDF_FORTRAN_ROOT"
      export HDF5="$HDF5_ROOT"

[compile.WRF]

job-header-option-time=03:00:00
job-header-option-partition=zen16
job-header-option-mem=12GB

shell=export YACC="byacc -d"
      export FLEX_LIB_DIR="/usr/lib/x86_64-linux-gnu"

configure-opt=34

[compile.WPS]

job-header-option-time=00:15:00

configure-opt=2

[run.all]

cmd-python=/proju/wrf-chem/software/micromamba/micromamba
           run
           --root-prefix=/proju/wrf-chem/software/conda-envs/shared
           --name=WRF-Chem-Polar
           python
