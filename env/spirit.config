#
# Plateform-specific options for compiling WRF, WRF-Chem, and WPS on Spirit.

[common]

job_exe=/usr/bin/sbatch

job_header=SBATCH --ntasks=<ntasks>
           SBATCH --ntasks-per-node=<ntasks_per_node>
           SBATCH --output=<stdout>
           SBATCH --error=<stderr>
           SBATCH --time=<walltime>
           SBATCH --partition=<partition>
           SBATCH --mem=<memory>

shell=module purge
      module load gcc/11.2.0
      module load openmpi/4.0.7
      module load netcdf-c/4.7.4-serial
      module load netcdf-fortran/4.5.3-serial

[compile.all]

job_header_replace_ntasks=1
job_header_replace_ntasks_per_node=1
job_header_replace_stdout=compile.log
job_header_replace_stderr=compile.log

shell=export NETCDF="$NETCDF_FORTRAN_ROOT"
      export HDF5="$HDF5_ROOT"

[compile.WRF]

job_header_replace_walltime=03:00:00
job_header_replace_partition=zen16
job_header_replace_memory=12GB

shell=export YACC="byacc -d"
      export FLEX_LIB_DIR="/usr/lib/x86_64-linux-gnu"

configure_opt=34

[compile.WPS]

job_header_replace_walltime=00:15:00
job_header_replace_partition=zen4
job_header_replace_memory=3840MB

configure_opt=2

[run.all]

cmd_python=/proju/wrf-chem/software/micromamba/micromamba
           run
           --root-prefix=/proju/wrf-chem/software/conda-envs/shared
           --name=WRF-Chem-Polar
           python
