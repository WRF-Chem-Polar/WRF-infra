#
# Plateform-specific options for compiling WRF, WRF-Chem, and WPS on Jed.

[common]

job-exe=/usr/bin/sbatch
job-header-prefix=#SBATCH --
job-header-separator==

shell=module purge
      module load gcc/13.2.0
      module load openmpi/5.0.3
      export MODULEPATH=$MODULEPATH:/work/eerl/wrf-chem-polar/software/libraries/gcc-v13.2.0/module_files
      module --ignore_cache load zlib-v1.3.1.module
      module --ignore_cache load hdf5-v1.14.6_zlib-v1.3.1.module
      module --ignore_cache load netcdf-fortran-v4.6.2_netcdf-c-v4.9.3_hdf5-v1.14.6_zlib-v1.3.1.module

[compile.all]

job-header-option-ntasks=1
job-header-option-ntasks-per-node=1
job-header-option-output=compile.log
job-header-option-error=compile.log

shell=export NETCDF="$NETCDF_FORTRAN_ROOT"
      export HDF5="$HDF5_ROOT"

[compile.WRF]

job-header-option-time=03:00:00

shell=module load flex/2.6.1-y4a5vd2
      export YACC="byacc -d"
      export FLEX_LIB_DIR="${FLEX_ROOT}/lib"

configure-opt=34

[compile.WPS]

job-header-option-time=00:15:00

configure-opt=2

[run.all]

cmd-python=/work/eerl/apdasilv/wrf-chem-polar/software/micromamba/micromamba
            run
            --root-prefix=/work/eerl/wrf-chem-polar/software/conda-envs/shared
            --name=WRF-Chem-Polar
            python
